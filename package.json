{
  "name": "claude-channel-mux",
  "version": "0.3.0",
  "description": "Multi-channel session multiplexer for Claude Code — routes Slack and Telegram conversations to independent CC sessions via MCP.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "daemon": "bun install --no-summary && bun daemon.ts",
    "start": "bun install --no-summary && bun server.ts",
    "build:wasm": "cd zellij-plugin && cargo build --release --target wasm32-wasip1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@slack/web-api": "^7.8.0",
    "@slack/socket-mode": "^2.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "claude-code",
    "mcp",
    "slack",
    "telegram",
    "multiplexer",
    "channel"
  ]
}
